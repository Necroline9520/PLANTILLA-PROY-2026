        "standard_column_names = [\n",
        "    'Feria', 'Comuna', 'Fecha_Precio',\n",
        "    'Novillo_Gordo_Precio_kg', 'Novillo_Engorda_Precio_kg',\n",
        "    'Vaca_Gorda_Precio_kg', 'Vaca_Engorda_Precio_kg',\n",
        "    'Vaquilla_Gorda_Precio_kg', 'Vaquilla_Engorda_Precio_kg',\n",
        "    'Toros_Precio_kg', 'Terneros_Precio_kg', 'Terneras_Precio_kg',\n",
        "    'Cerdos_Precio_kg', 'Lanares_Precio_kg', 'Caballos_Precio_kg'\n",
        "]\n",
        "\n",
        "# Columnas de precios para conversión de tipo\n",
        "price_columns = [\n",
        "    'Novillo_Gordo_Precio_kg', 'Novillo_Engorda_Precio_kg',\n",
        "    'Vaca_Gorda_Precio_kg', 'Vaca_Engorda_Precio_kg',\n",
        "    'Vaquilla_Gorda_Precio_kg', 'Vaquilla_Engorda_Precio_kg',\n",
        "    'Toros_Precio_kg', 'Terneros_Precio_kg', 'Terneras_Precio_kg',\n",
        "    'Cerdos_Precio_kg', 'Lanares_Precio_kg', 'Caballos_Precio_kg'\n",
        "]\n",
        "\n",
        "# Headers para simular una solicitud de navegador\n",
        "headers = {\n",
        "    'User-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'\n",
        "}\n",
        "\n",
        "# Asumiendo que `excel_links` ya está definido desde la ejecución de la celda `ba1e7b1a`\n",
        "# Si `excel_links` no estuviera definido, esta celda fallaría. Se asume que el usuario ejecutó `ba1e7b1a`.\n",
        "\n",
        "all_consolidated_dfs = []\n",
        "\n",
        "for excel_url in excel_links:\n",
        "    # Extraer el nombre del archivo de la URL\n",
        "    file_name = os.path.join(DOWNLOAD_DIR, excel_url.split('/')[-1])\n",
        "\n",
        "    print(f\"\\nProcesando: {excel_url}\")\n",
        "\n",
        "    try:\n",
        "        # Descargar el archivo Excel\n",
        "        response = requests.get(excel_url, stream=True, headers=headers)\n",
        "        response.raise_for_status()\n",
        "\n",
        "        with open(file_name, 'wb') as f:\n",
        "            for chunk in response.iter_content(chunk_size=8192):\n",
        "                f.write(chunk)\n",
        "        print(f\"Archivo '{os.path.basename(file_name)}' descargado exitosamente.\")\n",
        "\n",
        "        # Leer el archivo Excel y concatenar hojas\n",
        "        xls = pd.ExcelFile(file_name)\n",
        "        sheet_names_to_read = xls.sheet_names[1:4] # Hojas 2, 3 y 4 (indices 1, 2, 3)\n",
        "\n",
        "        current_excel_dfs = []\n",
        "        for sheet_name in sheet_names_to_read:\n",
        "            # Leer la hoja sin encabezados para procesarla manualmente\n",
        "            df_raw = pd.read_excel(xls, sheet_name=sheet_name, header=None)\n",
        "\n",
        "            # Verificar si hay suficientes filas para el encabezado y datos\n",
        "            if df_raw.shape[0] < 9: # Necesitamos al menos la fila 9 para el encabezado (índice 8) y datos después\n",
        "                print(f\"ADVERTENCIA: Hoja '{sheet_name}' en '{os.path.basename(file_name)}' tiene muy pocas filas. Saltando.\")\n",
        "                continue\n",
        "\n",
        "            # La fila de encabezado real es la 9ª (índice 8)\n",
        "            # Los datos comienzan en la 10ª fila (índice 9)\n",
        "            df_temp = df_raw.iloc[9:].copy()\n",
        "            df_temp.columns = df_raw.iloc[8].values # Usar la fila 9 como nombres de columna\n",
        "\n",
        "            # Limpiar nombres de columna (eliminar espacios, saltos de línea, etc.)\n",
        "            df_temp.columns = [str(col).strip().replace('\\n', ' ').replace('\\r', '') if pd.notna(col) else f'Columna_Unnamed_{idx}' for idx, col in enumerate(df_temp.columns)]\n",
        "\n",
        "            # Crear un DataFrame con las columnas estándar y rellenar con datos si existen\n",
        "            processed_df = pd.DataFrame(columns=standard_column_names)\n",
        "\n",
        "            for i, col_name_std in enumerate(standard_column_names):\n",
        "                if i < len(df_temp.columns):\n",
        "                    # Intentar mapear por posición, que es más robusto si los nombres varían ligeramente\n",
        "                    processed_df[col_name_std] = df_temp.iloc[:, i]\n",
        "                else:\n",
        "                    processed_df[col_name_std] = np.nan # Rellenar con NaN si la columna no existe\n",
        "\n",
        "            # Convertir 'Fecha_Precio' a datetime, manejando errores\n",
        "            if 'Fecha_Precio' in processed_df.columns:\n",
        "                processed_df['Fecha_Precio'] = pd.to_datetime(processed_df['Fecha_Precio'], errors='coerce')\n",
        "\n",
        "            # Convertir columnas de precios a numéricas, manejando errores\n",
        "            for col in price_columns:\n",
        "                if col in processed_df.columns:\n",
        "                    processed_df[col] = pd.to_numeric(processed_df[col], errors='coerce')\n",
        "\n",
        "            # Filtrar filas donde las columnas clave están todas vacías (posibles filas de totales o notas)\n",
        "            # Usamos un subconjunto de columnas clave para esta limpieza\n",
        "            key_columns_for_dropna = [col for col in ['Feria', 'Comuna', 'Fecha_Precio'] if col in processed_df.columns]\n",
        "            if key_columns_for_dropna:\n",
        "                processed_df.dropna(subset=key_columns_for_dropna, how='all', inplace=True)\n",
        "\n",
        "            if not processed_df.empty:\n",
        "                processed_df['Origen_Archivo'] = os.path.basename(file_name)\n",
        "                current_excel_dfs.append(processed_df)\n",
        "                print(f\"Datos de '{os.path.basename(file_name)}' - Hoja '{sheet_name}' procesados correctamente. Filas: {processed_df.shape[0]}\")\n",
        "            else:\n",
        "                print(f\"ADVERTENCIA: Hoja '{sheet_name}' en '{os.path.basename(file_name)}' resultó en DataFrame vacío después de limpieza. Saltando.\")\n",
        "\n",
        "        if current_excel_dfs:\n",
        "            df_excel_consolidated = pd.concat(current_excel_dfs, ignore_index=True)\n",
        "            all_consolidated_dfs.append(df_excel_consolidated)\n",
        "            print(f\"Datos de '{os.path.basename(file_name)}' procesados correctamente. Total filas consolidadas para este archivo: {df_excel_consolidated.shape[0]}\")\n",
        "        else:\n",
        "            print(f\"No se pudieron procesar datos de '{os.path.basename(file_name)}' de las hojas especificadas.\")\n",
        "\n",
        "        # Opcional: Eliminar el archivo Excel después de procesarlo\n",
        "        os.remove(file_name)\n",
        "\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"Error al descargar/acceder a '{excel_url}': {e}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Ocurrió un error al procesar '{os.path.basename(file_name)}': {e}\")\n",
        "\n",
        "if all_consolidated_dfs:\n",
        "    df_data_all = pd.concat(all_consolidated_dfs, ignore_index=True)\n",
        "    print(\"\\n--- Consolidación Final ---\")\n",
        "    print(f\"Todos los datos de Odepa han sido consolidados en un único DataFrame con forma: {df_data_all.shape}\")\n",
        "    display(df_data_all.head())\n",
        "    print(\"Información general del DataFrame consolidado:\")\n",
