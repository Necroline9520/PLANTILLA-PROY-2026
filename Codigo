        "    merged_df_enhanced[f'Maiz_Price_Lag{lag}'] = merged_df_enhanced['Maiz_Price'].shift(lag)\n",
        "\n",
        "# --- Rolling Statistics ---\n",
        "windows = [3, 6, 12] # Rolling windows for 3, 6, and 12 months\n",
